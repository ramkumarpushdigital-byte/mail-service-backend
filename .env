# ─── Gmail SMTP ───────────────────────────────────────────────────────────────
# Your Gmail address used to send emails
GMAIL_USER=ramkumar.pushdigital@gmail.com

# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2FA to be enabled on your Google account
GMAIL_APP_PASSWORD=hmxb hxug oyje odvn

# ─── Email Addresses ──────────────────────────────────────────────────────────
# The "From" display name and address in outgoing emails
EMAIL_FROM="Push Digital" <ramkumar.pushdigital@gmail.com>
    
# Where enquiry emails are delivered to
ENQUIRY_RECIPIENT=ramkumarramar2237@gmail.com

# ─── SMTP Timeout ─────────────────────────────────────────────────────────────
# Milliseconds before SMTP is considered unreachable (default: 8000)
SMTP_TIMEOUT_MS=8000

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on (Render sets this automatically)
PORT=5000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your frontend domain. Use * for development or set exact domain in production.
# Example: https://push.digital
FRONTEND_URL=*
